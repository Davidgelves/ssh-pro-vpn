#!/bin/bash
clear
#--------------------------
# SCRIPR SSH-PLUS
# Dev. J DAVID AG
#--------------------------

# - Cores
RED='\033[1;31m'
YELLOW='\033[1;33m'
SCOLOR='\033[0m'

# - Verifica Execucao Como Root
[[ "$EUID" -ne 0 ]] && {
    echo -e "${RED}[x] Debe ejecutarse como usuario root.${SCOLOR}"
    exit 1
}

# - Verifica Arquitetura Compativel
case "$(uname -m)" in
    'amd64' | 'x86_64')
        arch='64'
        ;;
    'aarch64' | 'armv8')
        arch='arm64'
        ;;
    *)
        echo -e "${RED}[x] Arquitectura no compatible.${SCOLOR}"
        exit 1
        ;;
esac

# - Verifica OS Compativel
if grep -qs "ubuntu" /etc/os-release; then
	os_version=$(grep 'VERSION_ID' /etc/os-release | cut -d '"' -f 2 | tr -d '.')
    [[ "$os_version" -lt 1804 ]] && {
        echo -e "${RED}[x] Versión de Ubuntu no compatible.\n${YELLOW}[!] Se requiere Ubuntu 18.04 o superior.${SCOLOR}"
        exit 1
    }
elif [[ -e /etc/debian_version ]]; then
	os_version=$(grep -oE '[0-9]+' /etc/debian_version | head -1)
    [[ "$os_version" -lt 9 ]] && {
        echo -e "${RED}[x] Versión de Debian no compatible.\n${YELLOW}[!] Se requiere Debian 9 o superior.${SCOLOR}"
        exit 1
    }
else
    echo -e "${RED}[x] Sistema no compatible.\n${YELLOW}[!] Se requiere Debian/Ubuntu.${SCOLOR}"
    exit 1
fi

# - Atualiza Lista/Pacotes/Sistema
dpkg --configure -a
apt update -y && apt upgrade -y
apt install -y unzip python3 curl wget

# - Desabilita ipv6
sysctl -w net.ipv6.conf.all.disable_ipv6=1 && sysctl -p
echo 'net.ipv6.conf.all.disable_ipv6 = 1' > /etc/sysctl.d/70-disable-ipv6.conf
sysctl -p -f /etc/sysctl.d/70-disable-ipv6.conf

# - Executa instalador: local ou fallback (pipe /dev/fd)
_SSHPLUS_RAW_MAIN="https://raw.githubusercontent.com/Davidgelves/sshpro-main/main"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
INSTALLER_LOCAL="${BASE_DIR}/script/${arch}/Plus"

run_plus() {
    chmod +x "$1"
    exec "$1"
}

if [[ -f "${INSTALLER_LOCAL}" ]]; then
    run_plus "${INSTALLER_LOCAL}"
fi

_PLUS_URL="${_SSHPLUS_RAW_MAIN}/script/${arch}/Plus"
TMP_PLUS="$(mktemp)"
if command -v curl >/dev/null 2>&1; then
    curl -fsSL "${_PLUS_URL}" -o "${TMP_PLUS}" || true
elif command -v wget >/dev/null 2>&1; then
    wget -qO "${TMP_PLUS}" "${_PLUS_URL}" || true
fi
if [[ -s "${TMP_PLUS}" ]]; then
    run_plus "${TMP_PLUS}"
fi

echo -e "${RED}[x] No se pudo cargar el instalador Plus.${SCOLOR}"
exit 1
