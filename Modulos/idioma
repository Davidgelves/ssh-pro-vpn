#!/bin/bash
# Cambiar idioma del menu SSH-PLUS (principal y submenu opcion 23)
clear
mkdir -p /etc/SSHPlus
[[ -f /etc/SSHPlus/lang ]] || echo es >/etc/SSHPlus/lang
atual=$(tr -d '[:space:]' < /etc/SSHPlus/lang 2>/dev/null)
[[ -z "$atual" ]] && atual=es

echo -e "\033[1;31mв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—\033[0m"
echo -e "\033[1;31mв•‘  \033[1;33mSSH-PLUS вҖ” \033[1;32mIDIOMA / LANGUAGE / IDIOMA\033[0m \033[1;31m                  в•‘"
echo -e "\033[1;31mв• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј\033[0m"
echo -e "\033[1;31mв•‘  \033[1;37mActual / Actual / Atual: \033[1;32m$atual\033[0m"
echo -e "\033[1;31mв• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј\033[0m"
echo -e "\033[1;31mв•‘  \033[1;36m[1]\033[1;37m  EspaГұol (predeterminado)\033[0m"
echo -e "\033[1;31mв•‘  \033[1;36m[2]\033[1;37m  PortuguГӘs\033[0m"
echo -e "\033[1;31mв•‘  \033[1;36m[0]\033[1;37m  Volver / Voltar\033[0m"
echo -e "\033[1;31mв•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ\033[0m"
echo -ne "\033[1;32mOpciГіn: \033[1;33m"
read -r op
case "$op" in
1)
	echo es >/etc/SSHPlus/lang
	echo -e "\033[1;32mIdioma: EspaГұol. Reinicia el menГә (sal y ejecuta menu).\033[0m"
	;;
2)
	echo pt >/etc/SSHPlus/lang
	echo -e "\033[1;32mIdioma: PortuguГӘs. Reinicie o menu.\033[0m"
	;;
0|00|"")
	;;
*)
	echo -e "\033[1;31mOpciГіn no vГЎlida.\033[0m"
	;;
esac
sleep 2
