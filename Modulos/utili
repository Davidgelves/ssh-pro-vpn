#!/bin/bash
# lang=es utili
# blocksite no se sincroniza por wget: el repo remoto podía seguir sirviendo el binario PT y machacaba /bin/blocksite.
_sshplus_sync_herramientas_submodulos() {
	for _m in blockt ddos multi blockuser badvpn2 badvpn3 badpro badpro1 menub mudardata delhost reiniciarservicos senharoot v2raymanager; do
		if [[ ! -f "/bin/$_m" ]] || ! grep -aFq "lang=es $_m" "/bin/$_m" 2>/dev/null; then
			wget -qO "/bin/$_m" "https://raw.githubusercontent.com/Davidgelves/sshpro-main/main/Modulos/$_m" && chmod +x "/bin/$_m"
		fi
	done
}
# Instala en /bin/blocksite el script en español (embebido) antes de ejecutarlo; no depende de GitHub ni del binario antiguo.
_sshplus_install_blocksite_es() {
	cat >/bin/blocksite <<'BLOCKSITE_EMBED'
#!/bin/bash
# lang=es blocksite
# Bloqueo de dominios en Squid (túnel SSH / VPN). Sustituye el binario antiguo (solo PT).

_blocksite_paths() {
	if [[ -d /etc/squid ]] && [[ -f /etc/squid/squid.conf ]]; then
		VAR_SQD="/etc/squid/squid.conf"
		BLOCK_LIST="/etc/squid/blocked.txt"
	elif [[ -d /etc/squid3 ]] && [[ -f /etc/squid3/squid.conf ]]; then
		VAR_SQD="/etc/squid3/squid.conf"
		BLOCK_LIST="/etc/squid3/blocked.txt"
	else
		return 1
	fi
	return 0
}

_blocksite_reload() {
	if [[ -d /etc/squid ]]; then
		service squid reload 2>/dev/null || /etc/init.d/squid reload 2>/dev/null || service squid restart 2>/dev/null
	fi
	if [[ -d /etc/squid3 ]]; then
		service squid3 reload 2>/dev/null || /etc/init.d/squid3 reload 2>/dev/null || service squid3 restart 2>/dev/null
	fi
}

_blocksite_ensure_acl() {
	if grep -q 'acl blocked_sites' "$VAR_SQD" 2>/dev/null; then
		return 0
	fi
	if ! grep -q 'acl payload url_regex' "$VAR_SQD" 2>/dev/null; then
		echo -e "\033[1;31mNo se encontró la ACL de payload en squid.conf. Instale o repare Squid desde el menú de conexión.\033[0m"
		sleep 3
		return 1
	fi
	touch "$BLOCK_LIST"
	chmod 644 "$BLOCK_LIST" 2>/dev/null
	local tmp
	tmp=$(mktemp)
	awk -v bf="$BLOCK_LIST" '
		/acl payload url_regex/ {
			print
			print "\t\tacl blocked_sites dstdomain -i \"" bf "\""
			next
		}
		/^[\t ]*http_access allow payload/ {
			print "\t\thttp_access deny blocked_sites"
			print
			next
		}
		{ print }
	' "$VAR_SQD" >"$tmp" && mv "$tmp" "$VAR_SQD"
	return 0
}

_blocksite_norm() {
	local h
	h=$(echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
	[[ -z "$h" ]] && return 1
	h="${h#http://}"
	h="${h#https://}"
	h="${h%%/*}"
	h="${h#www.}"
	[[ -z "$h" ]] && return 1
	h=".${h#.}"
	echo "$h"
}

_blocksite_do_block() {
	local d
	d=$(_blocksite_norm "$1") || return 1
	if grep -Fxq "$d" "$BLOCK_LIST" 2>/dev/null; then
		echo -e "\033[1;33mEl dominio ya está en la lista bloqueada.\033[0m"
		sleep 2
		return 0
	fi
	echo "$d" >>"$BLOCK_LIST"
	sort -u "$BLOCK_LIST" -o "$BLOCK_LIST"
	_blocksite_reload
	echo -e "\033[1;32mDominio bloqueado: $d\033[0m"
	sleep 2
}

_blocksite_do_unblock() {
	local d
	d=$(_blocksite_norm "$1") || return 1
	if ! grep -Fxq "$d" "$BLOCK_LIST" 2>/dev/null; then
		echo -e "\033[1;33mEse dominio no está en la lista.\033[0m"
		sleep 2
		return 0
	fi
	grep -Fxv "$d" "$BLOCK_LIST" >"${BLOCK_LIST}.tmp" && mv "${BLOCK_LIST}.tmp" "$BLOCK_LIST"
	_blocksite_reload
	echo -e "\033[1;32mDominio desbloqueado: $d\033[0m"
	sleep 2
}

_blocksite_do_unblock_all() {
	: >"$BLOCK_LIST"
	_blocksite_reload
	echo -e "\033[1;32mLista de bloqueo vaciada.\033[0m"
	sleep 2
}

_blocksite_do_list() {
	echo -e "\033[1;33mDominios bloqueados (\033[1;37m$BLOCK_LIST\033[1;33m):\033[0m"
	echo ""
	if [[ ! -s "$BLOCK_LIST" ]]; then
		echo -e "\033[1;31m(lista vacía)\033[0m"
	else
		echo -e "\033[1;36m"
		cat "$BLOCK_LIST"
		echo -e "\033[0m"
	fi
	echo ""
	read -r -p "$(echo -e "\033[1;32mPulse Enter para continuar...\033[0m")" _
}

while true; do
