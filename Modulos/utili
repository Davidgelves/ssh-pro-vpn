		;;
	4 | 04)
		_blocksite_do_list
		;;
	0 | 00)
		clear
		break
		;;
	*)
		echo -e "\033[1;31mOpción no válida.\033[0m"
		sleep 2
		;;
	esac
done
BLOCKSITE_EMBED
	chmod +x /bin/blocksite
