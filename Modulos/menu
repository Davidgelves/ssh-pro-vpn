swap1=$(printf '%-5s' "$(LC_ALL=C free -h 2>/dev/null | awk '/^Swap:/{print $2}')")
swap2=$(printf '%-5s' "$(LC_ALL=C free -h 2>/dev/null | awk '/^Swap:/{print $4}')")
swap3=$(printf '%-5s' "$(LC_ALL=C free -h 2>/dev/null | awk '/^Swap:/{print $3}')")
[[ -z "$swap1" ]] && swap1='-'
clear
_sshplus_box_top
_sshplus_title
_sshplus_box_triple
_sshplus_line_g " ${L_SISTEMA:-SISTEMA}  OS:${_system}  ${L_HORA:-Hora}:${_hora}"
_sshplus_line_c " ${L_MEM_RAM:-RAM}  T:${_ram}  ${L_EM_USO:-En uso}:${_usor}"
_sshplus_line_c " ${L_PROCESSADOR:-CPU}  ${L_NUCLEOS:-Nucleos}:${_core}  ${L_EM_USO:-En uso}:${_usop}"
_sshplus_box_triple_mid
_sshplus_line_g " ${L_ONLINES:-On}:$_onlin  ${L_EXPIR:-Exp}:$_userexp  ${L_TOTAL:-Tot}:$_tuser"
_sshplus_box_triple_bot
_sshplus_line_c " ${L_MEM_SWAP:-SWAP}  T:${swap1}  ${L_EM_USO:-U}:${swap3}  ${L_LIVRE:-L}:${swap2}"
_sshplus_box_sep
_sshplus_pair "01" "${L_M01:-CREAR USUARIO}" "12" "${L_M12:-SPEEDTEST}"
_sshplus_pair "02" "${L_M02:-CRIAR TESTE}" "13" "${L_M13:-BANNER}"
_sshplus_pair "03" "${L_M03:-REMOVER USUARIO}" "14" "${L_M14:-TRAFEGO}"
_sshplus_pair "04" "${L_M04:-MONITOR ONLINE}" "15" "${L_M15:-OTIMIZAR}"
_sshplus_pair "05" "${L_M05:-MUDAR DATA}" "16" "${L_M16:-BACKUP}"
_sshplus_pair "06" "${L_M06:-ALTERAR LIMITE}" "17" "${L_M17:-FERRAMENTAS}"
_sshplus_pair "07" "${L_M07:-MUDAR SENHA}" "18" "${L_M18:-LIMITER} ${stsl}"
_sshplus_pair "08" "${L_M08:-REMOVER EXPIRADOS}" "19" "${L_M19:-Menu BadVpn} ${stsu}"
_sshplus_pair "09" "${L_M09:-INFORME DE USUARIOS}" "20" "${L_M20:-FIREWALL (PRO)}"
_sshplus_pair "10" "${L_M10:-MODO DE CONEXAO}" "21" "${L_M21:-INFO VPS} >>"
_sshplus_pair "11" "${L_M11:-CRIAR MEMORIA SWAP}" "22" "${L_M22:-CHECKUSER 4G}"
_sshplus_pair_g "${L_MG:-CHECKUSER GLTUNNEL}" "${L_M23:-MAIS} >>"
_sshplus_box_bot
_sshplus_prompt; read x

case "$x" in 
   1 | 01)
   clear
   _sshplus_sync_criarusuario
   criarusuario
   ;;
   2 | 02)
   clear
   _sshplus_sync_criarteste
   criarteste
   echo -ne "\n\033[1;31mENTER \033[1;33m${L_ENTER_MENU:-para volver al menú}\033[0m"; read
   ;;
   3 | 03)
   clear
   remover
   sleep 3
   ;;
   4 | 04)
   clear
   sshmonitor
   echo -ne "\n\033[1;31mENTER \033[1;33m${L_ENTER_MENU:-para volver al menú}\033[0m"; read
   ;;      
   5 | 05)
   clear
   mudardata
   sleep 3
   ;;
   6 | 06)
   clear
   alterarlimite
   sleep 3
   ;; 
   7 | 07)
   clear
   _sshplus_sync_alterarsenha
   alterarsenha
   sleep 3
   ;;
   8 | 08)
   clear
   _sshplus_sync_expcleaner
   expcleaner
   echo ""
   sleep 3
   ;;     
   9 | 09)
   clear
   infousers
   echo -ne "\n\033[1;31mENTER \033[1;33m${L_ENTER_MENU:-para volver al menú}\033[0m"; read
   ;;
   10)
   conexao
   exit;
   ;;
   11)
   swapmemory
   ;;
   12)
   clear
   velocity
   echo -ne "\n\033[1;31mENTER \033[1;33m${L_ENTER_MENU:-para volver al menú}\033[0m"; read
   ;;
   13)
   clear
   banner
   sleep 3
   ;;
   14)
   clear
   echo -e "\033[1;32mPARA SAIR CLICK CTRL + C\033[1;36m"
   sleep 4
   nload
   ;;
   15)
   clear
   otimizar
   echo -ne "\n\033[1;31mENTER \033[1;33m${L_ENTER_MENU:-para volver al menú}\033[0m"; read
   ;;
   16)
   userbackup
   echo -ne "\n\033[1;31mENTER \033[1;33m${L_ENTER_MENU:-para volver al menú}\033[0m"; read
   ;;
   17)
   clear
   utili
   ;;
   18)
   limit_ssh
   ;;
   19)
   clear
   menub
   exit;
   ;;
   20)
   fr
   ;;
   21)
   clear
   detalhes
   echo -ne "\n\033[1;31mENTER \033[1;33m${L_ENTER_MENU:-para volver al menú}\033[0m"; read
   ;;
   22)
   initcheck
   ;;
   23|023)
   menu2
   ;;
   g|G)
   gltunnel
   ;;
   0|00)
   clear
   ;;
   *)
   echo -e "\n\033[1;31m${L_OPC_INVALIDA:-Opcion no valida!}\033[0m"
   sleep 2
esac
done
}
menu
