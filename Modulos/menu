_sshplus_line() { local s; s=$(_sshplus_pad66 "$1"); printf $'\033[1;31m|\033[0m\033[1;37m%s\033[0m\033[1;31m|\033[0m\n' "$s"; }
_sshplus_line_g() { local s; s=$(_sshplus_pad66 "$1"); printf $'\033[1;31m|\033[0m\033[1;32m%s\033[0m\033[1;31m|\033[0m\n' "$s"; }
_sshplus_line_c() { local s; s=$(_sshplus_pad66 "$1"); printf $'\033[1;31m|\033[0m\033[1;36m%s\033[0m\033[1;31m|\033[0m\n' "$s"; }
_sshplus_title() {
	local s=" SSH-PLUS  Dev. J DAVID AG "
	s="${s:0:66}"
	while [[ ${#s} -lt 66 ]]; do s+=' '; done
	printf $'\033[1;31m|\033[0m\033[5;34;47m%s\033[0m\033[1;31m|\033[0m\n' "$s"
}
_sshplus_pair() {
	local n1="$1" n2="$3" a b
	a=$(_sshplus_pad24 "$2")
	b=$(_sshplus_pad24 "$4")
	printf $'\033[1;31m|\033[0m  \033[1;36m[%2s]\033[1;37m - \033[1;33m%s\033[0m  \033[1;36m[%2s]\033[1;37m - \033[1;33m%s\033[0m\033[1;31m|\033[0m\n' "$n1" "$a" "$n2" "$b"
}
_sshplus_pair_g() {
	local a b
	a=$(_sshplus_pad24 "$1")
	b=$(_sshplus_pad24 "$2")
	printf $'\033[1;31m|\033[0m  \033[1;36m[ G ]\033[1;37m - \033[1;33m%s\033[0m  \033[1;36m[%2s]\033[1;37m - \033[1;33m%s\033[0m\033[1;31m|\033[0m\n' "$a" "23" "$b"
}
_sshplus_line_00() {
	local t="${L2_00} <<"
	t="${t:0:58}"
	while [[ ${#t} -lt 58 ]]; do t+=' '; done
	printf $'\033[1;31m|\033[0m  \033[1;36m[00]\033[1;37m - \033[1;33m%s\033[0m\033[1;31m|\033[0m\n' "$t"
}
