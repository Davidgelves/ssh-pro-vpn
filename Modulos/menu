swap2="${swap2//[[:space:]]/}"
swap3="$(LC_ALL=C LANG=C free -h 2>/dev/null | awk '$1 == "Swap:" {print $3; exit}')"
swap3="${swap3//[[:space:]]/}"
[[ -z "${swap1// }" ]] && swap1='0B'
[[ -z "${swap2// }" ]] && swap2='0B'
[[ -z "${swap3// }" ]] && swap3='0B'
clear
