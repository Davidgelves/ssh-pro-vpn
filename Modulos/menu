# Marco interno 66 columnas (original estrecho con pad10 recortaba el español).
_SSHPLUS_IW=66
_sshplus_pad24() {
	local s="${1:0:24}"
	while [[ ${#s} -lt 24 ]]; do s+=' '; done
	echo -n "$s"
}
_sshplus_pad66() {
	local s="${1:0:66}"
	while [[ ${#s} -lt 66 ]]; do s+=' '; done
	echo -n "$s"
}
_sshplus_box_top() { echo -e "\033[1;31m+$(printf '%66s' '' | tr ' ' '-')+\033[0m"; }
_sshplus_box_bot() { echo -e "\033[1;31m+$(printf '%66s' '' | tr ' ' '-')+\033[0m"; }
