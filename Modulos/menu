_sshplus_pair() {
	local n1="$1" l1="$2" n2="$3" l2="$4"
	local left right
	left=$(printf '%-28.28s' "   [${n1}] • ${l1}")
	right=$(printf '%-32.32s' "[${n2}] • ${l2}")
	_sshplus_line "${left}${right}"
}
_sshplus_pair_g() {
	local lg="$1" l23="$2"
	local left right
	left=$(printf '%-28.28s' "   [ G ] • ${lg}")
	right=$(printf '%-32.32s' "[23] • ${l23}")
	_sshplus_line "${left}${right}"
