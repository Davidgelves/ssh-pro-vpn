# Marco interno 66 columnas. Bordes Unicode (línea continua ┌─┐│). Tras borde izq. van SIEMPRE 2 espacios (igual que el panel).
_SSHPLUS_IW=66
_sshplus_pad24() {
	local s="${1:0:24}"
	while [[ ${#s} -lt 24 ]]; do s+=' '; done
	echo -n "$s"
}
_sshplus_pad66() {
	local s="${1:0:66}"
	while [[ ${#s} -lt 66 ]]; do s+=' '; done
	echo -n "$s"
}
_sshplus_hbar() { local i; for ((i=0;i<_SSHPLUS_IW;i++)); do printf '─'; done; }
_sshplus_box_top() { printf '\033[1;31m┌'; _sshplus_hbar; printf '┐\033[0m\n'; }
_sshplus_box_bot() { printf '\033[1;31m└'; _sshplus_hbar; printf '┘\033[0m\n'; }
_sshplus_box_sep() { printf '\033[1;31m├'; _sshplus_hbar; printf '┤\033[0m\n'; }
_sshplus_box_triple() { _sshplus_box_sep; }
_sshplus_box_triple_mid() { _sshplus_box_sep; }
_sshplus_box_triple_bot() { _sshplus_box_sep; }
_sshplus_line() { local s; s=$(_sshplus_pad66 "$1"); printf '\033[1;31m│\033[0m\033[1;37m%s\033[0m\033[1;31m│\033[0m\n' "$s"; }
_sshplus_line_g() { local s; s=$(_sshplus_pad66 "$1"); printf '\033[1;31m│\033[0m\033[1;32m%s\033[0m\033[1;31m│\033[0m\n' "$s"; }
_sshplus_line_c() { local s; s=$(_sshplus_pad66 "$1"); printf '\033[1;31m│\033[0m\033[1;36m%s\033[0m\033[1;31m│\033[0m\n' "$s"; }
_sshplus_title() {
	local t="SSH-PRO" w=${#t} l=$(( (_SSHPLUS_IW - w) / 2 )) r=$(( _SSHPLUS_IW - w - l ))
	printf '\033[1;31m│\033[0m%*s\033[1;34m%s\033[0m%*s\033[1;31m│\033[0m\n' "$l" '' "$t" "$r" ''
}
# Panel 3×20; separador · (no |) para no confundir con borde. 2+20+1+20+1+20+2=66 entre │ y │
_sshplus_cell20() { printf '%-20.20s' "$1"; }
_sshplus_draw_sys_dashboard() {
	local sw a b c
	a=$(_sshplus_cell20 "${L_SISTEMA:-SISTEMA}")
	b=$(_sshplus_cell20 "${L_MEM_RAM:-MEMORIA RAM}")
	c=$(_sshplus_cell20 "${L_PROCESSADOR:-PROCESADOR}")
	printf '\033[1;31m│\033[0m  \033[1;32m%s\033[0m·\033[1;32m%s\033[0m·\033[1;32m%s\033[0m  \033[1;31m│\033[0m\n' "$a" "$b" "$c"
	a=$(_sshplus_cell20 "OS:${_system}")
	b=$(_sshplus_cell20 "Total:${_ram}")
	c=$(_sshplus_cell20 "${L_NUCLEOS:-Nuc}:${_core}")
	printf '\033[1;31m│\033[0m  \033[1;37m%s\033[0m·\033[1;37m%s\033[0m·\033[1;37m%s\033[0m  \033[1;31m│\033[0m\n' "$a" "$b" "$c"
	a=$(_sshplus_cell20 "${L_HORA:-Hora}:${_hora}")
	b=$(_sshplus_cell20 "RAM:${_usor}")
	c=$(_sshplus_cell20 "CPU:${_usop}")
	printf '\033[1;31m│\033[0m  \033[1;37m%s\033[0m·\033[1;37m%s\033[0m·\033[1;37m%s\033[0m  \033[1;31m│\033[0m\n' "$a" "$b" "$c"
	_sshplus_box_sep
	if [[ ! -e /tmp/att ]]; then
		a=$(_sshplus_cell20 "${L_ONLINES:-Conectados}")
		b=$(_sshplus_cell20 "${L_EXPIR:-Caducados}")
		c=$(_sshplus_cell20 "${L_TOTAL:-Total}")
		printf '\033[1;31m│\033[0m  \033[1;32m%s\033[0m·\033[1;32m%s\033[0m·\033[1;32m%s\033[0m  \033[1;31m│\033[0m\n' "$a" "$b" "$c"
		a=$(_sshplus_cell20 "${_onlin}")
		b=$(_sshplus_cell20 "${_userexp}")
		c=$(_sshplus_cell20 "${_tuser}")
		printf '\033[1;31m│\033[0m  \033[1;37m%s\033[0m·\033[1;37m%s\033[0m·\033[1;37m%s\033[0m  \033[1;31m│\033[0m\n' "$a" "$b" "$c"
	else
		printf '\033[1;31m│\033[0m\033[1;33m%-66.66s\033[0m\033[1;31m│\033[0m\n' "[!] ${L_ATUAL_DISP:-ACTUALIZACION DISPONIBLE} [!]"
	fi
	_sshplus_box_sep
	sw=" ${L_MEM_SWAP:-SWAP}  ${L_TOTAL:-Total}: ${swap1}  ${L_EM_USO:-En uso}: ${swap3}  ${L_LIVRE:-Libre}: ${swap2} "
	_sshplus_line_c "$sw"
}
_sshplus_pair() {
	local n1="$1" n2="$3" a b s
	a=$(_sshplus_pad24 "$2")
	b=$(_sshplus_pad24 "$4")
	printf -v s '  [%2s] - %-24.24s  [%2s] - %-24.24s' "$n1" "$a" "$n2" "$b"
	while [[ ${#s} -lt ${_SSHPLUS_IW} ]]; do s+=' '; done
	s="${s:0:${_SSHPLUS_IW}}"
	printf '\033[1;31m│\033[0m  \033[1;36m%s\033[1;37m%s\033[1;33m%s\033[1;36m%s\033[1;37m%s\033[1;33m%s\033[0m  \033[1;31m│\033[0m\n' \
		"${s:2:4}" "${s:6:3}" "${s:9:24}" "${s:35:4}" "${s:39:3}" "${s:42:24}"
}
_sshplus_pair_g() {
	local a b s
	a=$(_sshplus_pad24 "$1")
	b=$(_sshplus_pad24 "$2")
	printf -v s '  [ G ] - %-24.24s  [%2s] - %-23.23s' "$a" "23" "$b"
	while [[ ${#s} -lt ${_SSHPLUS_IW} ]]; do s+=' '; done
	s="${s:0:${_SSHPLUS_IW}}"
	printf '\033[1;31m│\033[0m  \033[1;36m%s\033[1;37m%s\033[1;33m%s\033[1;36m%s\033[1;37m%s\033[1;33m%s\033[0m  \033[1;31m│\033[0m\n' \
		"${s:2:5}" "${s:7:3}" "${s:10:24}" "${s:36:4}" "${s:40:3}" "${s:43:23}"
}
_sshplus_line_00() {
	local t="${L2_00} <<" s
	t="${t:0:57}"
	while [[ ${#t} -lt 57 ]]; do t+=' '; done
	printf -v s '  [00] - %s' "$t"
	while [[ ${#s} -lt ${_SSHPLUS_IW} ]]; do s+=' '; done
	s="${s:0:${_SSHPLUS_IW}}"
	printf '\033[1;31m│\033[0m  \033[1;36m%s\033[1;37m%s\033[1;33m%s\033[0m  \033[1;31m│\033[0m\n' "${s:2:4}" "${s:6:3}" "${s:9:57}"
}
