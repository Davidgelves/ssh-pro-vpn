[[ -z "${_usop// }" ]] && _usop='?'
_core="$(command -v nproc >/dev/null 2>&1 && nproc || grep -c ^processor /proc/cpuinfo)"
_system="$(echo -n "$system" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
_system="${_system:0:14}"
_hora=$(printf '%(%H:%M:%S)T')
_onlin="$_onli"
_userexp="$_expuser"
