#!/usr/bin/env bash
set -Eeuo pipefail

# Entry point saneado:
# - Sin descargas remotas ni ejecucion dinamica.
# - Delega en instalador local auditado.

if [[ "${EUID}" -ne 0 ]]; then
  echo "Ejecuta como root: sudo ./ssh-plus"
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SAFE_INSTALLER="${SCRIPT_DIR}/instalar-badvpn-seguro.sh"

if [[ ! -f "${SAFE_INSTALLER}" ]]; then
  echo "No se encontro ${SAFE_INSTALLER}."
  exit 1
fi

chmod 750 "${SAFE_INSTALLER}"
exec "${SAFE_INSTALLER}"
